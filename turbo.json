{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "cacheDir": ".turbo/cache",
  "envMode": "strict",
  "futureFlags": {
    "affectedUsingTaskInputs": true,
    "filterUsingTasks": true,
    "watchUsingTaskInputs": true
  },
  "globalDependencies": [
    "package.json",
    "bun.lock",
    "turbo.json",
    "tooling/configs/*.yaml.example",
    "tooling/configs/gateway.compose.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", "dist/**"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "interruptible": true,
      "persistent": true,
      "outputLogs": "new-only"
    },
    "eval": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "generate": {
      "outputs": [".output/**"],
      "outputLogs": "new-only"
    },
    "test": {
      "outputs": [],
      "outputLogs": "new-only"
    },
    "test:coverage": {
      "outputs": [],
      "outputLogs": "new-only"
    },
    "train": {
      "cache": false,
      "outputLogs": "new-only"
    },
    "typecheck": {
      "outputs": [],
      "outputLogs": "new-only"
    },
    "verify": {
      "outputs": [],
      "outputLogs": "new-only"
    }
  }
}
