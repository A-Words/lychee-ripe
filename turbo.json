{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["LYCHEE_PY_TARGET"],
  "tasks": {
    "build": {
      "outputs": [".output/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "eval": {
      "cache": false
    },
    "generate": {
      "outputs": [".output/**"]
    },
    "test": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "verify": {
      "outputs": []
    }
  }
}
