server:
  host: "0.0.0.0"
  port: 9000
  read_timeout_s: 30
  write_timeout_s: 60

upstream:
  base_url: "http://127.0.0.1:8000"
  timeout_s: 30

db:
  driver: "sqlite" # sqlite | postgres
  dsn: "mlops/artifacts/data/gateway.db" # repo-root-relative sqlite file path or postgres DSN
  max_open_conns: 10
  max_idle_conns: 5
  conn_max_lifetime_s: 300
  sqlite:
    journal_mode: "WAL"
    busy_timeout_ms: 5000
  postgres:
    ssl_mode: "disable"
    schema: "public"

seed:
  default_resources_enabled: true # local demo orchard/plot seed data; disable for production

trace:
  mode: "database" # database | blockchain

chain:
  rpc_url: "http://127.0.0.1:8545"
  chain_id: "31337"
  contract_address: "0x1234567890abcdef1234567890abcdef12345678"
  private_key: "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" # local dev only
  tx_timeout_s: 30
  receipt_poll_interval_ms: 500

auth:
  mode: "disabled" # disabled | oidc
  bootstrap_admin_email: "" # required for first startup with auth.mode=oidc on an empty users table
  oidc:
    issuer_url: "https://issuer.example.com" # the access_token presented to gateway must include an email claim for first-time user binding
    audience: "lychee-ripe"
    web_client_id: "orchard-console-web"
  web:
    public_base_url: "http://127.0.0.1:9000" # gateway external url used for /v1/auth/callback
    app_base_url: "http://127.0.0.1:3000" # orchard-console external url used for post-login redirect
    cookie_name: "lychee_session"
    cookie_secure: false # set true behind https
    cookie_same_site: "lax" # use "none" with cookie_secure=true for cross-site web deployments
    session_ttl_s: 3600 # fallback session duration when OIDC token has no explicit expiry
    session_cleanup_interval_s: 1800 # background purge interval for expired sessions/auth states

rate_limit:
  enabled: true
  requests_per_second: 20
  burst: 40
  exclude_paths:
    - "/healthz"

cors:
  enabled: true
  allowed_origins:
    - "http://127.0.0.1:3000"
  allowed_methods:
    - "GET"
    - "POST"
    - "PATCH"
    - "DELETE"
    - "OPTIONS"
  allowed_headers:
    - "Content-Type"
    - "Authorization"
  allow_credentials: true
  max_age_s: 3600

logging:
  level: "info"
  format: "json"
